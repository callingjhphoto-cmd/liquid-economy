# Liquid Economy Intelligence Platform — Environment Variables
# Copy this to .env and fill in your values

# Database (Railway provides this automatically)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/liquid_economy

# Auth
SECRET_KEY=generate-a-random-32-char-hex-string
ADMIN_USERNAME=palmer
ADMIN_PASSWORD=your-secure-password-here

# API Keys (all free registration)
BLS_API_KEY=                    # https://data.bls.gov/registrationEngine/
SEC_USER_AGENT=Palmer Liquid Studios james@huertas.co.uk
COMPANIES_HOUSE_API_KEY=        # https://developer.company-information.service.gov.uk/

# Collector schedules (cron format)
SCHEDULE_YAHOO_FINANCE=0 7 * * 1-5
SCHEDULE_BLS_PPI=0 9 15 * *
SCHEDULE_SEC_EDGAR=0 6 * * 1-5
